<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="default">

    <!-- ─────────── ESCENA: iluminación & desactivar sombras ─────────── -->
<scene>
  <ambient>1 1 1 1</ambient>          <!-- Iluminación blanca -->
  <background>1 1 1 1</background>    <!-- Fondo blanco puro -->
  <shadows>false</shadows>
</scene>


    <!-- ─────────── PLUGINS ROS–GAZEBO ─────────── -->
    <plugin name="gazebo_ros_api_plugin" filename="libgazebo_ros_api_plugin.so"/>
    <plugin name="gazebo_ros_factory"  filename="libgazebo_ros_factory.so"/>
    <plugin name="gazebo_ros_state"    filename="libgazebo_ros_state.so"/>

    <!-- ─────────── SOL y SUELO ─────────── -->
    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <!-- ─────────── PAREDES 20x20 ─────────── -->
    <!-- Izquierda -->
    <model name="wall_left">
      <static>true</static>
      <pose>-10 0 1 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.2 20 2</size></box></geometry></collision>
        <visual    name="visual"><geometry><box><size>0.2 20 2</size></box></geometry>
          <material><ambient>0.0 0.0 0.0 1</ambient></material>
        </visual>
      </link>
    </model>
    <!-- Derecha -->
    <model name="wall_right">
      <static>true</static>
      <pose>10 0 1 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.2 20 2</size></box></geometry></collision>
        <visual    name="visual"><geometry><box><size>0.2 20 2</size></box></geometry>
          <material><ambient>0.0 0.0 0.0 1</ambient></material>
        </visual>
      </link>
    </model>
    <!-- Inferior -->
    <model name="wall_bottom">
      <static>true</static>
      <pose>0 -10 1 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>20 0.2 2</size></box></geometry></collision>
        <visual    name="visual"><geometry><box><size>20 0.2 2</size></box></geometry>
          <material><ambient>0.0 0.0 0.0 1</ambient></material>
        </visual>
      </link>
    </model>
    <!-- Superior -->
    <model name="wall_top">
      <static>true</static>
      <pose>0 10 1 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>20 0.2 2</size></box></geometry></collision>
        <visual    name="visual"><geometry><box><size>20 0.2 2</size></box></geometry>
          <material><ambient>0.0 0.0 0.0 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- ─────────── FÍSICA ─────────── -->
    <physics name="default_physics" type="ode">
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <!-- max_step_size>0.001</max_step_size  version anterior -->
      <max_step_size>0.004</max_step_size>
      <use_real_time>false</use_real_time>
      <ode>
        <solver><type>quick</type><iters>40</iters><sor>1.3</sor></solver>
        <constraints><cfm>1e-5</cfm><erp>0.3</erp></constraints>
      </ode>
    </physics>

    <!-- ─────────── GUI ─────────── -->
    <gui fullscreen="0">
      <camera name="user_camera">
        <pose>0 -18 15 0.5 0.8 0</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
      </camera>
    </gui>

    <!-- ─────────── Obstáculos modelo pool ─────────── -->
    <!-- Estos <model> deben corresponder con box_names en tu Python -->
    <model name="box_00">
      <static>false</static><kinematic>true</kinematic>
      <pose>-2.5 -2.5 0.35 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.9 1.1 0.7</size></box></geometry></collision>
        <visual    name="vis"><geometry><box><size>0.9 1.1 0.7</size></box></geometry>
          <material><ambient>0.8 0.2 0.2 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- Repetir box_01…box_14 -->
    <model name="box_01">
      <static>false</static><kinematic>true</kinematic>
      <pose>2.5 -2.5 0.35 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.8 1.0 0.6</size></box></geometry></collision>
        <visual    name="vis"><geometry><box><size>0.8 1.0 0.6</size></box></geometry>
          <material><ambient>0 1 0 1</ambient></material>
        </visual>
      </link>
    </model>


    <model name="box_02">
    <static>false</static><kinematic>true</kinematic>
    <pose>2.5 2.5 0.35 0 0 0</pose>
    <link name="link">
        <collision name="col">
        <geometry>
            <cylinder>
            <radius>0.6</radius>
            <length>0.9</length>
            </cylinder>
        </geometry>
        </collision>
        <visual name="vis">
        <geometry>
            <cylinder>
            <radius>0.6</radius>
            <length>0.9</length>
            </cylinder>
        </geometry>
        <material>
            <ambient>1 0.5 0 1</ambient>  <!-- Naranjo -->
        </material>
        </visual>
    </link>
    </model>



    <model name="box_03">
    <static>false</static><kinematic>true</kinematic>  <!-- O true si no se mueve -->
    <pose>-2.5 2.5 0.35 0 0 0</pose>
    <link name="link">
        <collision name="col">
        <geometry>
            <cylinder>
            <radius>0.5</radius>
            <length>0.8</length>  <!-- Altura del cilindro -->
            </cylinder>
        </geometry>
        </collision>
        <visual name="vis">
        <geometry>
            <cylinder>
            <radius>0.5</radius>
            <length>0.8</length>
            </cylinder>
        </geometry>
        <material>
            <ambient>0 0 1 1</ambient> <!-- Naranjo -->
        </material>
        </visual>
    </link>
    </model>



  </world>
</sdf>

